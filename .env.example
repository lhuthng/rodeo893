# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=dev                  # dev | prod
FRONTEND_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://bakery:bakery@postgres:5432/bakery

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
SESSION_SECRET=changeme_at_least_32_chars_long_random
JWT_SECRET=changeme_staff_jwt_secret_at_least_32_chars

# ─── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=Bakery <no-reply@example.com>

# ─── Payment: ZaloPay ────────────────────────────────────────────────────────
PAYMENT_ZALOPAY_APP_ID=
PAYMENT_ZALOPAY_KEY1=
PAYMENT_ZALOPAY_KEY2=
PAYMENT_ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2

# ─── Payment: VNPay ──────────────────────────────────────────────────────────
PAYMENT_VNPAY_TMN_CODE=
PAYMENT_VNPAY_HASH_SECRET=
PAYMENT_VNPAY_ENDPOINT=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# ─── Payment: MoMo ───────────────────────────────────────────────────────────
PAYMENT_MOMO_PARTNER_CODE=
PAYMENT_MOMO_ACCESS_KEY=
PAYMENT_MOMO_SECRET_KEY=
PAYMENT_MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api

# ─── Delivery: GHN (Giao Hàng Nhanh) ─────────────────────────────────────────
DELIVERY_GHN_TOKEN=
DELIVERY_GHN_SHOP_ID=
DELIVERY_GHN_ENDPOINT=https://online-gateway.ghn.vn/shiip/public-api

# ─── Delivery: GHTK (Giao Hàng Tiết Kiệm) ───────────────────────────────────
DELIVERY_GHTK_TOKEN=
DELIVERY_GHTK_ENDPOINT=https://services.giaohangtietkiem.vn

# ─── Delivery: ViettelPost ────────────────────────────────────────────────────
DELIVERY_VIETTELPOST_TOKEN=
DELIVERY_VIETTELPOST_ENDPOINT=https://partner.viettelpost.vn/v2

# ─── Membership ──────────────────────────────────────────────────────────────
MEMBERSHIP_TOPUP_AMOUNT=5000000   # VND, amount required to activate membership
