# Local native dev environment — copy to .env.dev and fill in secrets.
# Used by: make dev-backend
# NOTE: uses localhost instead of Docker service names.

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=dev
FRONTEND_URL=http://localhost:5173

# ─── Database & Redis (localhost, started via make dev-db) ───────────────────
DATABASE_URL=postgres://bakery:bakery@localhost:5432/bakery
REDIS_URL=redis://localhost:6379

# ─── Auth (replace with real random strings, min 32 chars) ───────────────────
SESSION_SECRET=dev_session_secret_replace_me_32chars_min
JWT_SECRET=dev_jwt_secret_replace_me_32_chars_minimum

# ─── Membership ───────────────────────────────────────────────────────────────
MEMBERSHIP_TOPUP_AMOUNT=100000

# ─── SMTP (optional for dev, defaults to localhost:1025) ─────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM='Bakery <noreply@bakery.local>'
