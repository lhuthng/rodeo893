  "query": "SELECT id,reference_code,user_id,status as \"status: OrderStatus\",total_amount,currency,note,created_at,updated_at\n               FROM orders\n               WHERE ($1::uuid IS NULL OR user_id = $1)\n               AND   ($2::order_status IS NULL OR status = $2)\n               ORDER BY created_at DESC LIMIT $3 OFFSET $4",
